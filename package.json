{
  "name": "fitjourney",
  "version": "1.0.0",
  "description": "GLP-1 투약자를 위한 통합 건강 관리 웹앱 — 투약·체중·운동·식사를 한곳에서 기록하고 시각적으로 추적",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage --coverageReporters=text-summary",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report e2e-report"
  },
  "keywords": ["health", "glp-1", "diet", "tracker", "localStorage"],
  "author": "FitJourney",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@axe-core/playwright": "^4.8.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "serve": "^14.2.0"
  }
}
